{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(app/**)",
      "Write(components/**)",
      "Write(lib/**)",
      "Write(schemas/**)",
      "Write(sanity/**)",
      "Write(styles/**)",
      "Write(data/**)",
      "Write(docs/**)",
      "Write(public/**)",
      "Write(.claude/**)",
      "Write(types/**)",
      "Write(src/**)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(gh *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(sanity *)",
      "Bash(next *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Write(.env*)",
      "Write(**/.env*)",
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(pnpm *)"
    ]
  }
}
