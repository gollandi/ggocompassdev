import { useState, useEffect } from "react";
import { AnimatePresence } from "motion/react";
import { loadPreferences, applyAccessibilityClasses } from "./utils/preferences";
import { SplashScreen } from "./components/screens/SplashScreen";
import { WelcomeScreen } from "./components/screens/WelcomeScreen";
import { PersonaliseScreen, PersonalisePreferences } from "./components/screens/PersonaliseScreen";
import { ModeSelectScreen } from "./components/screens/ModeSelectScreen";
import { ProcedurePickerScreen } from "./components/screens/ProcedurePickerScreen";
import { DateInputScreen } from "./components/screens/DateInputScreen";
import { TimelineScreen } from "./components/screens/TimelineScreen";
import { RecoveryScreen } from "./components/screens/RecoveryScreen";
import { FeedbackScreen } from "./components/screens/FeedbackScreen";
import { CompletionScreen } from "./components/screens/CompletionScreen";
import { ExportVariablesScreen } from "./components/screens/ExportVariablesScreen";
import { MicrocopyStyleGuideScreen } from "./components/screens/MicrocopyStyleGuideScreen";

type Screen = 
  | "splash" 
  | "welcome" 
  | "personalise" 
  | "mode-select" 
  | "procedure-picker" 
  | "date-input" 
  | "timeline"
  | "recovery" 
  | "feedback" 
  | "completion"
  | "export-variables"
  | "microcopy-styles";

interface JourneyData {
  preferences?: PersonalisePreferences;
  mode?: "explore" | "track";
  procedure?: string;
  site?: string;
  date?: Date;
  feedbackRating?: number;
  feedbackComments?: string;
}

export default function App() {
  const [currentScreen, setCurrentScreen] = useState<Screen>("splash");
  const [journeyData, setJourneyData] = useState<JourneyData>({});

  // Load and apply accessibility preferences on mount
  useEffect(() => {
    const prefs = loadPreferences();
    applyAccessibilityClasses(prefs.accessibility);
  }, []);

  const handleSplashComplete = () => {
    setCurrentScreen("welcome");
  };

  const handleBegin = () => {
    setCurrentScreen("personalise");
  };

  const handlePersonaliseNext = (preferences: PersonalisePreferences) => {
    setJourneyData({ ...journeyData, preferences });
    
    // Apply accessibility classes when preferences change
    const prefs = loadPreferences();
    applyAccessibilityClasses(prefs.accessibility);
    
    setCurrentScreen("mode-select");
  };

  const handleModeSelect = (mode: "explore" | "track") => {
    setJourneyData({ ...journeyData, mode });
    setCurrentScreen("procedure-picker");
  };

  const handleExportVariables = () => {
    setCurrentScreen("export-variables");
  };

  const handleBackFromExport = () => {
    setCurrentScreen("mode-select");
  };

  const handleViewMicrocopyStyles = () => {
    setCurrentScreen("microcopy-styles");
  };

  const handleBackFromMicrocopy = () => {
    setCurrentScreen("mode-select");
  };

  const handleProcedureNext = (procedure: string, site: string) => {
    setJourneyData({ ...journeyData, procedure, site });
    // Explore mode: Skip date input, go straight to timeline
    // Track mode: Need date first
    if (journeyData.mode === "explore") {
      setCurrentScreen("timeline");
    } else {
      setCurrentScreen("date-input");
    }
  };

  const handleDateNext = (date: Date) => {
    setJourneyData({ ...journeyData, date });
    // If we have procedure info already, user is returning from mode switch
    // Show timeline (they can skip through if they've seen it)
    setCurrentScreen("timeline");
  };

  const handleBrowseMode = () => {
    // User clicked "Skip date - Just browsing" link
    // This sets mode to exploring and shows timeline first
    setJourneyData({ ...journeyData, mode: "exploring" });
    setCurrentScreen("timeline");
  };

  const handleTimelineComplete = () => {
    setCurrentScreen("recovery");
  };

  const handleRecoveryComplete = () => {
    setCurrentScreen("feedback");
  };

  const handleFeedbackNext = (rating: number, comments: string) => {
    setJourneyData({ ...journeyData, feedbackRating: rating, feedbackComments: comments });
    setCurrentScreen("completion");
  };

  const handleExport = () => {
    // In a real app, this would generate a PDF
    alert("PDF export would be generated here with your journey summary.");
  };

  const handleReset = () => {
    setJourneyData({});
    setCurrentScreen("welcome");
  };

  // Apply reduced-motion class if user preference set
  const reducedMotion = journeyData.preferences?.accessibility.includes("Reduced Motion");
  
  return (
    <div className={`min-h-screen ${reducedMotion ? 'reduced-motion' : ''}`}>
      <AnimatePresence mode="wait">
        {currentScreen === "splash" && (
          <SplashScreen key="splash" onComplete={handleSplashComplete} />
        )}
        
        {currentScreen === "welcome" && (
          <WelcomeScreen key="welcome" onBegin={handleBegin} />
        )}
        
        {currentScreen === "personalise" && (
          <PersonaliseScreen key="personalise" onNext={handlePersonaliseNext} />
        )}
        
        {currentScreen === "mode-select" && (
          <ModeSelectScreen 
            key="mode-select" 
            onSelectMode={handleModeSelect}
            onExportVariables={handleExportVariables}
            onViewMicrocopyStyles={handleViewMicrocopyStyles}
          />
        )}

        {currentScreen === "export-variables" && (
          <ExportVariablesScreen
            key="export-variables"
            onBack={handleBackFromExport}
          />
        )}

        {currentScreen === "microcopy-styles" && (
          <MicrocopyStyleGuideScreen
            key="microcopy-styles"
            onBack={handleBackFromMicrocopy}
          />
        )}
        
        {currentScreen === "procedure-picker" && (
          <ProcedurePickerScreen key="procedure-picker" onNext={handleProcedureNext} />
        )}
        
        {currentScreen === "date-input" && journeyData.procedure && journeyData.site && (
          <DateInputScreen 
            key="date-input" 
            procedure={journeyData.procedure}
            site={journeyData.site}
            onNext={handleDateNext}
            onBrowseMode={handleBrowseMode}
          />
        )}
        
        {currentScreen === "timeline" && journeyData.procedure && journeyData.site && (
          <TimelineScreen
            key="timeline"
            procedure={journeyData.procedure}
            site={journeyData.site}
            date={journeyData.date}
            preferences={journeyData.preferences}
            onComplete={handleTimelineComplete}
          />
        )}
        
        {currentScreen === "recovery" && journeyData.procedure && journeyData.site && (
          <RecoveryScreen
            key="recovery"
            procedure={journeyData.procedure}
            site={journeyData.site}
            preferences={journeyData.preferences}
            mode={journeyData.mode || "exploring"}
            surgeryDate={journeyData.date}
            onComplete={handleRecoveryComplete}
            onModeChange={(newMode) => {
              // If switching to tracking mode without a date, prompt for date
              if (newMode === "tracking" && !journeyData.date) {
                setJourneyData({ ...journeyData, mode: newMode });
                setCurrentScreen("date-input");
              } else {
                setJourneyData({ ...journeyData, mode: newMode });
              }
            }}
          />
        )}
        
        {currentScreen === "feedback" && (
          <FeedbackScreen key="feedback" onNext={handleFeedbackNext} />
        )}
        
        {currentScreen === "completion" && (
          <CompletionScreen 
            key="completion" 
            onExport={handleExport}
            onReset={handleReset}
          />
        )}
      </AnimatePresence>
    </div>
  );
}
